generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TherapistProfile {
  id          String   @id @default(cuid())
  name        String   @default("Adriana Garibotti")
  description String   @default("Terapeuta")
  email       String   @default("")
  phone       String   @default("")
  photoUrl    String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSettings {
  id             String   @id @default(cuid())
  primaryColor   String   @default("#4a7c59")
  pageTitle      String   @default("Agende sua sessão")
  pageSubtitle   String   @default("Escolha o horário ideal para você. O processo é simples, seguro e rápido.")
  footerText     String   @default("© 2024 Adriana Garibotti · Pagamentos seguros via Mercado Pago")
  sessionPrice   Int      @default(150)
  sessionMinutes Int      @default(60)
  contentEnabled Boolean  @default(false)
  contentText    String   @default("")
  contentVideo   String   @default("")
  darkMode       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PaymentSettings {
  id              String   @id @default(cuid())
  mpEnabled       Boolean  @default(false)
  mpPublicKey     String   @default("")
  mpAccessToken   String   @default("")
  webhookUrl      String   @default("")
  stripeEnabled   Boolean  @default(false)
  stripePublicKey String   @default("")
  stripeSecretKey String   @default("")
  pixEnabled      Boolean  @default(false)
  pixKey          String   @default("")
  pixInstructions String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ScheduleSettings {
  id          String   @id @default(cuid())
  startHour   Int      @default(8)
  endHour     Int      @default(18)
  intervalMin Int      @default(60)
  workDays    String   @default("1,2,3,4,5")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AvailableSlot {
  id        String    @id @default(cuid())
  startTime DateTime
  endTime   DateTime
  isBooked  Boolean   @default(false)
  createdAt DateTime  @default(now())
  bookings  Booking[]
}

model Client {
  id        String    @id @default(cuid())
  name      String
  email     String
  phone     String    @default("")
  notes     String    @default("")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
}

model Booking {
  id          String        @id @default(cuid())
  slotId      String
  clientId    String?
  clientName  String
  clientEmail String
  clientPhone String        @default("")
  notes       String        @default("")
  value       Int           @default(150)
  status      BookingStatus @default(PENDING_PAYMENT)
  expiresAt   DateTime?
  meetLink    String        @default("")
  isManual    Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  slot        AvailableSlot @relation(fields: [slotId], references: [id])
  client      Client?       @relation(fields: [clientId], references: [id])
  payments    Payment[]
}

model Payment {
  id            String        @id @default(cuid())
  bookingId     String
  provider      String        @default("mercadopago")
  externalId    String?
  status        PaymentStatus @default(PENDING)
  amount        Int
  qrCode        String?
  qrCodeBase64  String?
  checkoutUrl   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  booking       Booking       @relation(fields: [bookingId], references: [id])
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  COMPLETED
  MANUAL
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}
